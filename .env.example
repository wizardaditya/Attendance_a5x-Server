PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=https://your-app.vercel.app
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/worksyne

COMPANY_NAME=A5x Industries

# ─────────────────────────────────────────────
# EMAIL — Option 1: Gmail SMTP via Nodemailer
# (Recommended — works for ANY recipient)
# Get App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
# ─────────────────────────────────────────────
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ─────────────────────────────────────────────
# EMAIL — Option 2: Resend
# (Free tier only sends to verified emails)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
